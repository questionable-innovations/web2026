{
  "name": "web2026",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "start": "pnpm --filter web start",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "contracts:build": "cd contracts && forge build",
    "contracts:test": "cd contracts && forge test",
    "contracts:fmt": "cd contracts && forge fmt",
    "contracts:deploy:fuji": "bash contracts/script/deploy-fuji.sh",
    "contracts:deploy:fuji:win": "powershell -ExecutionPolicy Bypass -File contracts/script/deploy-fuji.ps1"
  },
  "engines": {
    "node": ">=22 <24"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@reown/appkit",
      "better-sqlite3",
      "bufferutil",
      "canvas",
      "esbuild",
      "keccak",
      "sharp",
      "unrs-resolver",
      "utf-8-validate"
    ]
  }
}
