# --- Web app ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Chain ---
# Avalanche Fuji testnet by default. Switch to 43114 for C-chain mainnet.
NEXT_PUBLIC_CHAIN_ID=43113
NEXT_PUBLIC_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
NEXT_PUBLIC_CONTRACT_REGISTRY=0x0000000000000000000000000000000000000000

# Stablecoin used for deposits. dNZD if available on selected chain, else USDC.
NEXT_PUBLIC_DEPOSIT_TOKEN=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_DEPOSIT_TOKEN_SYMBOL=dNZD
NEXT_PUBLIC_DEPOSIT_TOKEN_DECIMALS=18

# --- Wallets ---
NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# --- IPFS pinning (Pinata) ---
PINATA_JWT=
NEXT_PUBLIC_IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs/

# --- Email OTP ---
RESEND_API_KEY=
EMAIL_FROM=noreply@example.com

# --- Server ---
DATABASE_URL=file:./data/app.db
SESSION_SECRET=change-me

# --- Deployer (server-side only, never expose) ---
DEPLOYER_PRIVATE_KEY=
